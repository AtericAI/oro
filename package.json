{
  "name": "oro",
  "version": "0.1.0",
  "description": "Open-source code quality engineer AI agent",
  "bin": {
    "oro": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:ui && npm run build:cli",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui": "cd oro/ui && npx vite build",
    "build:cli": "tsc -p tsconfig.cli.json && chmod +x dist/cli/index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "tsx watch oro/server/index.ts",
    "dev:ui": "cd oro/ui && npx vite"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "marked": "^12.0.2",
    "highlight.js": "^11.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orohq/oro"
  }
}
